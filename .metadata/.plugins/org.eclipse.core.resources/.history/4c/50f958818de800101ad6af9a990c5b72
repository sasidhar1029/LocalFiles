package com.strings;

public class Count_occurance_of_each_Char {

	public static void main(String[] args) {
		String s = "Sasidhar";
		int count = 1;
		for (int i = 0; i < s.length(); i++) {
			
			for (int j = i + 1; j < s.length(); j++) {
				if (s.charAt(i) == s.charAt(j)) {
					count++;
				}
			}
			System.out.println(s.charAt(i) + "-->" + count);
		}

	}

}
