package controller;   // recommended lowercase

import java.io.IOException;

import dao.BillDAO;
import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import model.Bill;

@WebServlet("/generateBill")
public class GenerateBillServlet extends HttpServlet {

    protected void doPost(HttpServletRequest req, HttpServletResponse resp)
            throws ServletException, IOException {

        Bill b = new Bill();

        b.setMeterNo(req.getParameter("meter"));

        int units = Integer.parseInt(req.getParameter("units"));

        double amount = BillDAO.calculateAmount(units);

        b.setUnits(units);
        b.setAmount(amount);
        b.setStatus("UNPAID");

        BillDAO.generateBill(b);

        resp.sendRedirect("dashboard.jsp");
    }
}